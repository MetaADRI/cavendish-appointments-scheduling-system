# Database - Primary (Neon/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Database - Fallback (local)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=cavendish_appointment_system

SESSION_SECRET=your_random_secret_here
PORT=3000

# Set to 'true' to enable slot tracking (reminders, presence, auto-finalize)
# On Vercel, run the scheduler separately via: npm run scheduler
ENABLE_SLOT_TRACKER=true

# Timezone (Africa/Lusaka = UTC+2)
TZ=Africa/Lusaka
SCHEDULER_TIMEZONE=Africa/Lusaka

# Scheduler settings
SCHEDULER_INTERVAL_SECONDS=30
REMINDER_MINUTES_BEFORE=10
SESSION_DURATION_MINUTES=30

# Vercel (set automatically by Vercel, do not change)
# VERCEL=1
